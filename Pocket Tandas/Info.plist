<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>Pocket Tandas uses Bluetooth to connect to a nearby phone for remote DJ control.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_pt-djremote._tcp</string>
		<string>_pt-djremote._udp</string>
	</array>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Pocket Tandas uses the local network to control playback between two phones running the app.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>
	<key>UIFileSharingEnabled</key>
	<true/>
</dict>
</plist>
